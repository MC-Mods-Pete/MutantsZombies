{
	"format_version": "1.19.0",
	"animation_controllers": {
		"controller.animation.model.new": {
			"initial_state": "idle",
			"states": {
				"idle": {
					"animations": ["new"],
					"transitions": [
						{"walking": "q.ground_speed > 1.0"}
					],
					"blend_transition": 0.2
				},
				"walking": {
					"animations": ["new2", "new4", "new3"],
					"sound_effects": [
						{"effect": ""}
					],
					"transitions": [
						{"idle": "q.ground_speed < 0.5"}
					],
					"blend_transition": 0.2
				}
			}
		}
	}
}